		"title": "etcd",
		"updated": "20220805131811"
	},
	"Children": [
		{
			"ID": "20220804161629-7fn9mip",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220804161629-7fn9mip",
				"updated": "20220804161806"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "本文主要介绍了etcd相关概念，以及etcd的主要使用场景"
				}
			]
		},
		{
			"ID": "20220804161809-dayudzi",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20220804161809-dayudzi",
				"updated": "20220804161815"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "1. 介绍"
				}
			]
		},
		{
			"ID": "20220804164657-clxuuv7",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220804164657-clxuuv7",
				"updated": "20220804164657"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\tetcd是云原生架构中的基础组件，由CNCF孵化托管。etcd在微服务和kubernetes集群中不仅可以作为服务注册中心用于服务发现，还可以作为key-value存储中间件"
				}
			]
		},
		{
			"ID": "20220804164859-l8qeuc9",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220804164859-l8qeuc9",
				"updated": "20220804165025"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\tetcd是CoreOS团队与2013年6月发起的开源项目，它的目标是构建一个高可用的分布式键值（key-value）数据库。具有以下特点："
				}
			]
		},
		{
			"ID": "20220804165030-thrwins",
			"Type": "NodeList",
			"ListData": {},
			"Properties": {
				"id": "20220804165030-thrwins",
				"updated": "20220805131456"
			},
			"Children": [
				{
					"ID": "20220804165031-sbv9emw",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165031-sbv9emw",
						"updated": "20220804165031"
					},
					"Children": [
						{
							"ID": "20220804165031-prn1txw",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165031-prn1txw",
								"updated": "20220804165131"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "简单：安装配置简单，而且提供了HTTP API进行交互，使用也很简单"
								}
							]
						}
					]
				},
				{
					"ID": "20220804165037-9cba4x9",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165037-9cba4x9",
						"updated": "20220805131456"
					},
					"Children": [
						{
							"ID": "20220804165037-vlvvrp9",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165037-vlvvrp9",
								"updated": "20220805131456"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "键值对存储：将数据存储在分层组织的目录中，如同 在标准文件系统中"
								}
							]
						}
					]
				},
				{
					"ID": "20220804165043-n1tvt2q",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165043-n1tvt2q"
					},
					"Children": [
						{
							"ID": "20220804165043-vqo2h06",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165043-vqo2h06",
								"updated": "20220805114110"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "检测变更：监测特定的键或目录以进行更改，并对值的更改做出反应"
								}
							]
						}
					]
				},
				{
					"ID": "20220804165053-kicbmoy",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165053-kicbmoy"
					},
					"Children": [
						{
							"ID": "20220804165053-r81c17c",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165053-r81c17c",
								"updated": "20220805112535"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "安全：支持SSL证书验证"
								}
							]
						}
					]
				},
				{
					"ID": "20220804165055-r139xir",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165055-r139xir"
					},
					"Children": [
						{
							"ID": "20220804165055-6nqsdxd",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165055-6nqsdxd",
								"updated": "20220805114154"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "快速：根据官方提供的benchmark数据，单实例支持每秒2k+读操作"
								}
							]
						}
					]
				},
				{
					"ID": "20220804165058-9wn0i8a",
					"Type": "NodeListItem",
					"ListData": {
						"BulletChar": 42,
						"Marker": "Kg=="
					},
					"Properties": {
						"id": "20220804165058-9wn0i8a"
					},
					"Children": [
						{
							"ID": "20220804165058-ruw97rl",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20220804165058-ruw97rl",
								"updated": "20220805114221"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "可靠：采用raft算法，实现分布式系统数据的可用性和一致性"
								}
							]
						}
					]
				}
			]
		},
		{
			"ID": "20220805114221-m175tku",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220805114221-m175tku",
				"updated": "20220805114416"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\tetcd采用Go语言编写，它具有出色的跨平台支持，很小的二进制文件和强大的社区。etcd机器之间的通信通过Raft算法处理。"
				}
			]
		},
		{
			"ID": "20220805114813-j9kc8i2",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220805114813-j9kc8i2",
				"updated": "20220805131118"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\tetcd是一个高度一致的分布式键值存储，它提供了一种可靠的方式来存储需要分布式系统或机器集群访问的数据。它可以优雅处理网络分区期间的leader选举，以应对机器的故障，即使是在leader节点发生故障时。"
				}
			]
		},
		{
			"ID": "20220805131530-ujjs7q8",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220805131530-ujjs7q8",
				"updated": "20220805131703"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\t从简单的Web应用程序到kubernetes集群，任何复杂的应用程序都可以从etcd中读取数据或将数据写入etcd。etcd于2018年12月正式加入云原生计算基金会CNCF，并由CNCF支持。"
				},
				{
					"Type": "NodeBr",
					"Data": "br"
				}
			]
		},
		{
			"ID": "20220804161815-vb0qhpd",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20220804161815-vb0qhpd",
				"updated": "20220804162039"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "2. 使用场景"
				}
			]
		},
