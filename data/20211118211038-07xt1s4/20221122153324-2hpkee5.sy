								},
								{
									"Type": "NodeInlineMathContent",
									"Data": " kubectl run -i --tty busybox --image=busybox -- sh  \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e \u003cspan class=\"code-snippet__comment\"\u003e# 连接到运行中的容器\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
