		{
			"ID": "20221122153324-4htdndc",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-4htdndc"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Kubectl 命令是操作 kubernetes 集群的最直接的方式，特别是运维人员，需要对这些命令有一个详细的掌握"
				}
			]
		},
		{
			"ID": "20221122153324-la54f21",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20221122153324-la54f21"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Kubectl 自动补全"
				}
			]
		},
		{
			"ID": "20221122153324-xfbr94h",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-xfbr94h"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"shell\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e# setup autocomplete in bash, bash-completion package should be installed first.\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " source \u0026lt;(kubectl completion bash) \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e # setup autocomplete in zsh\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " source "
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u0026lt;\u003c"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "(kubectl completion zsh)\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/section\u003e\u003c/pre\u003e"
				}
			]
		},
		{
			"ID": "20221122153324-b6mxr3j",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20221122153324-b6mxr3j"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Kubectl 上下文和配置"
				}
			]
		},
		{
			"ID": "20221122153324-x22te4b",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-x22te4b"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "设置 kubectl 命令交互的 kubernetes 集群并修改配置信息。参阅 使用 kubeconfig 文件进行跨集群验证 获取关于配置文件的详细信息。"
				}
			]
		},
		{
			"ID": "20221122153324-n9lbien",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-n9lbien"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"ruby\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 显示合并后的 kubeconfig 配置\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl config view \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 同时使用多个 kubeconfig 文件并查看合并后的配置\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " KUBECONFIG="
				},
				{
					"Type": "NodeSub",
					"Data": "sub",
					"Children": [
						{
							"Type": "NodeSubOpenMarker"
						},
						{
							"Type": "NodeText",
							"Data": "\u003cspan class=\"code-snippet__regexp\"\u003e/.kube/config\u003c/span\u003e\u003cspan class=\"code-snippet__symbol\"\u003e:"
						},
						{
							"Type": "NodeSubCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "/\u003c/span\u003e.kube/kubconfig2 kubectl config view\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 获取 e2e 用户的密码\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl config view -o jsonpath=\u003cspan class=\"code-snippet__string\"\u003e\u0026#39;{.users[?(@.name == \u0026#34;e2e\u0026#34;)].user.password}\u0026#39;\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 显示当前的上下文\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl config current-context    \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 设置默认上下文为 my-cluster-name\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl config use-context my-cluster-name  \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 向 kubeconf 中增加支持基本认证的新集群\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl config set-credentials kubeuser/foo.kubernetes.com --username=kubeuser --password=kubepassword\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 使用指定的用户名和 namespace 设置上下文\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e$ kubectl config set-context gce --user=cluster-admin --namespace=foo "
				},
				{
					"Type": "NodeBackslash",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeBackslashContent",
							"Data": "\u003c"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e  "
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u0026amp;\u0026"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u0026amp;\u0026"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl config use-context gce\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/section\u003e\u003c/pre\u003e"
				}
			]
		},
		{
			"ID": "20221122153324-5ywwyfx",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20221122153324-5ywwyfx"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "创建对象"
				}
			]
		},
		{
			"ID": "20221122153324-3j67taq",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-3j67taq"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "Kubernetes 的清单文件可以使用 json 或 yaml 格式定义。可以以 "
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u003cspan\u003e.yaml\u003c/span\u003e"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "、"
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u003cspan\u003e.yml\u003c/span\u003e"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "、或者 "
				},
				{
					"Type": "NodeCodeSpan",
					"Data": "code",
					"Children": [
						{
							"Type": "NodeCodeSpanOpenMarker"
						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u003cspan\u003e.json\u003c/span\u003e"
						},
						{
							"Type": "NodeCodeSpanCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " 为扩展名。"
				}
			]
		},
		{
			"ID": "20221122153324-7ubas03",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221122153324-7ubas03"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"sql\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 创建资源\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003ecreate\u003c/span\u003e -f ./my-manifest.yaml     \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 使用多个文件创建资源\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003ecreate\u003c/span\u003e -f ./my1.yaml -f ./my2.yaml   \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 使用目录下的所有清单文件来创建资源\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003ecreate\u003c/span\u003e -f ./dir    \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 使用 url 来创建资源\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003ecreate\u003c/span\u003e -f https://git.io/vPieo  \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 启动一个 nginx 实例\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl run nginx \u003cspan class=\"code-snippet__comment\"\u003e--image=nginx  \u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e \u003cspan class=\"code-snippet__comment\"\u003e# 获取 pod 和 svc 的文档\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
