						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"sql\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 删除 pod.json 文件中定义的类型和名称的 pod\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl \u003cspan class=\"code-snippet__keyword\"\u003edelete\u003c/span\u003e pod,service baz foo      \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 删除具有 name=myLabel 标签的 pod 和 serivce\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl \u003cspan class=\"code-snippet__keyword\"\u003edelete\u003c/span\u003e pods,services -l \u003cspan class=\"code-snippet__keyword\"\u003ename\u003c/span\u003e=myLabel \u003cspan class=\"code-snippet__comment\"\u003e--include-uninitialized   \u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 删除 my-ns namespace 下的所有 pod 和 serivce包\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e$ kubectl -n my-ns \u003cspan class=\"code-snippet__keyword\"\u003edelete\u003c/span\u003e po,svc \u003cspan class=\"code-snippet__comment\"\u003e--all\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/section\u003e\u003c/pre\u003e"
						},
