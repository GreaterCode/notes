						},
						{
							"Type": "NodeCodeSpanContent",
							"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"perl\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# dump 输出 pod 的日志（stdout）\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl logs \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-pod -c \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-container      \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 流式输出 pod 的日志（stdout）\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl logs -f \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-pod -c \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-container\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 交互式 shell 的方式运行 pod\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl attach \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-pod -i    \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 转发 pod 中的 6000 端口到本地的 5000 端口\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl \u003cspan class=\"code-snippet__keyword\"\u003eexec\u003c/span\u003e \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-pod -- ls /          \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 在已存在的容器中执行命令（pod 中有多个容器的情况下）\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e kubectl top pod POD_NAME --containers\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\u003c/section\u003e\u003c/pre\u003e"
						},
