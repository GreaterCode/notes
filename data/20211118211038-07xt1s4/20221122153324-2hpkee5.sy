									"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003eexec\u003c/span\u003e \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-pod -c \u003cspan class=\"code-snippet__keyword\"\u003emy\u003c/span\u003e-container -- ls /    \u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 显示指定 pod 和容器的指标度量\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
