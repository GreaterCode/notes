					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl expose rc nginx \u003cspan class=\"code-snippet__comment\"\u003e--port=80 --target-port=8000\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 更新单容器 pod 的镜像版本（tag）到 v4\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
