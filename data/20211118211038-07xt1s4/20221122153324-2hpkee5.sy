					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl rolling-\u003cspan class=\"code-snippet__keyword\"\u003eupdate\u003c/span\u003e frontend-v1 -f frontend-v2.json           \u003cspan class=\"code-snippet__comment\"\u003e# 滚动更新 pod frontend-v1\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003erolling\u003c/span\u003e-\u003cspan class=\"code-snippet__keyword\"\u003eupdate\u003c/span\u003e frontend-v1 frontend-v2 \u003cspan class=\"code-snippet__comment\"\u003e--image=image:v2  # 更新资源名称并更新镜像\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003erolling\u003c/span\u003e-\u003cspan class=\"code-snippet__keyword\"\u003eupdate\u003c/span\u003e frontend \u003cspan class=\"code-snippet__comment\"\u003e--image=image:v2                 # 更新 frontend pod 中的镜像\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003erolling\u003c/span\u003e-\u003cspan class=\"code-snippet__keyword\"\u003eupdate\u003c/span\u003e frontend-v1 frontend-v2 \u003cspan class=\"code-snippet__comment\"\u003e--rollback        # 退出已存在的进行中的滚动更新\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": " cat pod.json | kubectl \u003cspan class=\"code-snippet__keyword\"\u003ereplace\u003c/span\u003e -f -                              \u003cspan class=\"code-snippet__comment\"\u003e# 基于 stdin 输入的 JSON 替换 pod\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 强制替换，删除后重新创建资源。会导致服务中断。\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " kubectl \u003cspan class=\"code-snippet__keyword\"\u003ereplace\u003c/span\u003e \u003cspan class=\"code-snippet__comment\"\u003e--force -f ./pod.json\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e\u003cspan class=\"code-snippet__comment\"\u003e# 为 nginx RC 创建服务，启用本地 80 端口连接到容器上的 8000 端口\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
