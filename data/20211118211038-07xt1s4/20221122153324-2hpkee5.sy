			"Children": [
				{
					"Type": "NodeText",
					"Data": "\u003cpre\u003e\u003csection class=\"code-snippet__fix code-snippet__js\"\u003e\u003cpre class=\"code-snippet__js\" data-lang=\"sql\"\u003e\u003ccode\u003e\u003cspan class=\"code-snippet_outer\"\u003e"
				},
				{
