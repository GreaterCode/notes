		{
			"ID": "20221110180605-sknk6ls",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-sknk6ls"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "#!/bin/bash\nLANG=C\nPATH=/"
				},
				{
					"Type": "NodeLink",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeOpenBracket"
						},
						{
							"Type": "NodeLinkText",
							"Data": "sbin:/usr/sbin:/bin:/usr/bin"
						},
						{
							"Type": "NodeCloseBracket"
						},
						{
							"Type": "NodeOpenParen"
						},
						{
							"Type": "NodeLinkDest",
							"Data": "http://sbin/usr/sbin:/bin:/usr/bin"
						},
						{
							"Type": "NodeCloseParen"
						}
					]
				}
			]
		},
		{
			"ID": "20221110180605-ycmockd",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-ycmockd"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "#default second\ninterval=20\nbenchmark=50.0"
				}
			]
		},
		{
			"ID": "20221110180605-gwltpxn",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-gwltpxn"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "echo \"start gather system infos\" \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-uj8oz0b",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-uj8oz0b"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "while true\ndo\n  sleep ${interval}"
				}
			]
		},
		{
			"ID": "20221110180605-1pxrxtn",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-1pxrxtn"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  avg=$(cat /proc/loadavg)"
				}
			]
		},
		{
			"ID": "20221110180605-7pae0fq",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-7pae0fq"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  lavg1="
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo "
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{avg} | cut -d ' ' -f 1)\n  lavg5="
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo "
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{avg} | cut -d ' ' -f 2)\n  lavg15="
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo "
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{avg} | awk '{print $3}')"
				}
			]
		},
		{
			"ID": "20221110180605-k0sq0r9",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-k0sq0r9"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #manual trigger to debug\n  #lavg1="
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo \""
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{lavg1} + ${benchmark}\" | bc)"
				}
			]
		},
		{
			"ID": "20221110180605-20ka1zo",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-20ka1zo"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  if [ "
