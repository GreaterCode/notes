			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-lcldxtq"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #echo \"loadavg triger to gather system info\"  \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  #echo \""
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "{load1} "
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{load5} "
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "{load15}\" \u003e\u003e /var/log/cpu_loadavg_"
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-1f5fi1u",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-1f5fi1u"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #record the processes which are in running queue\n  echo -e \"\\n\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  date \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  echo -e \"The running queue has following processes:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  LANG=C ps -eTo stat,pid,tid,ppid,comm --no-header | sed -e 's/^ "
				},
				{
					"Type": "NodeBackslash",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeBackslashContent",
							"Data": "*"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "//' | perl -nE 'chomp;say if (m!^\\S"
				},
				{
					"Type": "NodeEmphasis",
					"Data": "em",
					"Children": [
						{
							"Type": "NodeEmA6kOpenMarker",
							"Data": "*"
						},
						{
							"Type": "NodeText",
							"Data": "[RD]+\\S"
						},
						{
							"Type": "NodeEmA6kCloseMarker",
							"Data": "*"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "!)' \u003e\u003e /var/log/cpu_loadavg_$$.txt 2\u003e\u00261"
				}
			]
		},
		{
			"ID": "20221110180605-zf5ym1o",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-zf5ym1o"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #record the top 50 processes of high cpu time\n  echo -e \"\\nThe top 50 processes:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  LANG=C ps -eT -o%cpu,pid,tid,ppid,comm | grep -v CPU | sort -n -r | head -50 \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  { LANG=C ps -eT -o%cpu,pid,tid,ppid,comm | sed -e 's/^ *//' | tr -s ' ' | grep -v CPU | sort -n -r | cut -d ' ' -f 1 | xargs -I{} echo -n \"{} + \" \u0026\u0026 echo ' 0'; } | bc -l \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-x1k9iwo",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20221110180605-x1k9iwo"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "for high cpu progress"
				}
			]
		},
		{
			"ID": "20221110180605-0oqwdc7",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-0oqwdc7"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  top -b -n 5 | grep PID -A 50 | grep -v PID \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-qteal7e",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-qteal7e"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #for low cpu high loadavg"
				}
			]
		},
		{
			"ID": "20221110180605-tqckv35",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20221110180605-tqckv35"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "record io stat"
				}
			]
		},
		{
			"ID": "20221110180605-q0yjpuw",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-q0yjpuw"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  echo -e \"\\nThe disk IO stat:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  iostat -d -x -m 1 10 \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-fm91ieu",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-fm91ieu"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  #record network io stat\n  echo -e \"The network IO stat:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  sar -n DEV 1 10 \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-5gcll8g",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20221110180605-5gcll8g"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "for high cpu high loadavg"
				}
			]
		},
		{
			"ID": "20221110180605-y7x8hjc",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-y7x8hjc"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  echo -e \"\\nThe top cpu:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  #only summary\n  #top -bi -n 5 \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  top -b -n 5 \u003e\u003e /var/log/cpu_loadavg_$$.txt"
				}
			]
		},
		{
			"ID": "20221110180605-qn4fj2k",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221110180605-qn4fj2k"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "  echo -e \"\\nThe vmstat stat:\\n\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  vmstat -n -t 5 10 \u003e\u003e /var/log/cpu_loadavg_$$.txt\n  #sleep ${interval}\ndone"
				}
			]
		},
