							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo \""
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{lavg1} \u003c ${benchmark}\" | bc) = 1  ] \u0026\u0026\n     [ "
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo \""
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{lavg5} \u003c ${benchmark}\" | bc) = 1  ] \u0026\u0026\n     [ "
				},
				{
					"Type": "NodeInlineMath",
					"Data": "span",
					"Children": [
						{
							"Type": "NodeInlineMathOpenMarker"
						},
						{
							"Type": "NodeInlineMathContent",
							"Data": "(echo \""
						},
						{
							"Type": "NodeInlineMathCloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": "{lavg15} \u003c ${benchmark}\" | bc) = 1 ]\n  then\n    echo \"debug script 1\" \u003e\u003e /var/log/cpu_loadavg_$$.txt\n    continue\n  fi"
				}
			]
		},
