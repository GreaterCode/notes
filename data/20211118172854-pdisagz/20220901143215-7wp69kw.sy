						},
						{
							"Type": "NodeCloseParen"
						}
					]
				}
			]
		},
		{
			"ID": "20220901143215-gadmc1r",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20220901143215-gadmc1r"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "很多红色 SACK，说明接收端那边重复在说：中间有一个包我没有收到，中间有一个包我没有收到。"
				}
			]
		},
		{
			"ID": "20220901143215-dzcdeaf",
			"Type": "NodeHeading",
			"HeadingLevel": 3,
			"Properties": {
				"id": "20220901143215-dzcdeaf"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "吞吐受到接收 window size 限制"
				}
			]
		},
		{
			"ID": "20220901143215-hqop8ye",
			"Type": "NodeParagraph",
			"Properties": {
