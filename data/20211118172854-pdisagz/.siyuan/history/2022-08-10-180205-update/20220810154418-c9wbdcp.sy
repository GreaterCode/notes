				}
			]
		},
		{
			"ID": "20220810174735-wxr4no4",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20220810174735-wxr4no4",
				"updated": "20220810174735"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "arcconf TASK START 1 DEVICE 0 8 uninitialize            # 去初始化阵列卡 Controller #1 下 Channel #0, Device #8 的硬盘\narcconf TASK START 1 DEVICE ALL uninitialize            # 去初始化阵列卡 Controller #1 下的所有硬盘\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
