		{
			"ID": "20220810164712-fbljdj5",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20220810164712-fbljdj5",
				"updated": "20220810175432"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "arcconf LIST　　　　　　　　　　#查询整列卡信息\narcconf GETCONFIG 1 AD      # 查询 Controller #1 的适配器信息\narcconf GETCONFIG 1 LD      # 查询 Controller #1 的逻辑设备信息\narcconf GETCONFIG 1 PD      # 查询 Controller #1 的物理设备信息\narcconf GETCONFIG 1 AR      # 查询 Controller #1 的阵列信息\narcconf GETCONFIG 1 AL      # 查询 Controller #1 的所有信息\narcconf GETCONFIG 1 LD|grep 'Logical Device number'     # 查询 Controller #1 的所有逻辑设备编号\narcconf GETCONFIG 1 LD|grep 'Logical Device name'       # 查询 Controller #1 的所有逻辑设备名称\narcconf GETCONFIG 1 PD|grep 'Device #'                  # 查询 Controller #1 的所有物理设备编号\narcconf GETCONFIG 1 LD|grep -E 'Logical Device number|Device:|Slot:'                # 查询 Controller #1 的所有逻辑设备对应的物理设备\narcconf GETCONFIG 1 LD|grep -E 'Logical Device number|RAID level|Device:|Slot:'     # 查询 Controller #1 的所有逻辑设备的RAID level以及物理设备\narcconf GETCONFIG 1 LD|grep -E 'Logical Device number|Logical Device name|RAID level|Device:|Slot:'     # 查询 Controller #1 的所有逻辑设备的关键信息\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
		{
			"ID": "20220810164808-iq5v1qk",
			"Type": "NodeHeading",
			"HeadingLevel": 1,
			"Properties": {
				"id": "20220810164808-iq5v1qk",
				"updated": "20220810174707"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "初始化"
				}
			]
		},
		{
			"ID": "20220810174707-w2n2fba",
			"Type": "NodeCodeBlock",
			"IsFencedCodeBlock": true,
			"Properties": {
				"id": "20220810174707-w2n2fba",
				"updated": "20220810174709"
			},
			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "YmFzaA=="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "arcconf TASK START 1 DEVICE 0 8 initialize              # 初始化阵列卡 Controller #1 下 Channel #0, Device #8 的硬盘\narcconf TASK START 1 DEVICE ALL initialize              # 初始化阵列卡 Controller #1 下的所有硬盘\n\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
