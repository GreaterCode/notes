						}
					]
				}
			]
		},
		{
			"ID": "20221112160356-zk70945",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221112160356-zk70945",
				"updated": "20221112160407"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\t在 OpenShift 中 ClusterOperaor 是由"
				},
				{
					"Type": "NodeText",
					"Data": " "
				},
				{
					"Type": "NodeMark",
					"Data": "mark",
					"Children": [
						{
							"Type": "NodeMark2OpenMarker"
						},
						{
							"Type": "NodeText",
							"Data": "Cluster Version Operator (CVO)"
						},
						{
							"Type": "NodeMark2CloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " "
				},
				{
					"Type": "NodeText",
					"Data": "管理的"
				}
			]
		},
		{
