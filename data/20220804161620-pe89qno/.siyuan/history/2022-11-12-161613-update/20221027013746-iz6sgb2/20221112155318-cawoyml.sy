			},
			"Children": [
				{
					"Type": "NodeStrong",
					"Data": "strong",
					"Children": [
						{
							"Type": "NodeStrongA6kOpenMarker",
							"Data": "**"
						},
						{
							"Type": "NodeText",
							"Data": "注意："
						},
						{
							"Type": "NodeStrongA6kCloseMarker",
							"Data": "**"
						}
					]
				}
			]
		},
		{
			"ID": "20221112160356-zk70945",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221112160356-zk70945",
				"updated": "20221112160407"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\t在 OpenShift 中 ClusterOperaor 是由"
				},
				{
					"Type": "NodeText",
					"Data": " "
				},
				{
					"Type": "NodeMark",
					"Data": "mark",
					"Children": [
						{
							"Type": "NodeMark2OpenMarker"
						},
						{
							"Type": "NodeText",
							"Data": "Cluster Version Operator (CVO)"
						},
						{
							"Type": "NodeMark2CloseMarker"
						}
					]
				},
				{
					"Type": "NodeText",
					"Data": " "
				},
				{
					"Type": "NodeText",
					"Data": "管理的"
				}
			]
		},
		{
			"ID": "20221112160429-5d2ihm2",
			"Type": "NodeHeading",
			"HeadingLevel": 2,
			"Properties": {
				"id": "20221112160429-5d2ihm2",
				"updated": "20221112160452"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "1.3 常规 Operator"
				}
			]
		},
		{
			"ID": "20221112160634-77dc00l",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221112160634-77dc00l",
				"updated": "20221112160813"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\t在 OpenShift 运行阶段根据需要安装的 Operator。有些常规 Operator 对象在所有 NameSpace 都有效，而有些则只能在特定 NameSpace 才能访问到，这取决于 Operator 自身特性以及在安装它们的时候选择的 NameSpace 范围。"
				}
			]
		},
		{
			"ID": "20221112161029-b59uzvi",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221112161029-b59uzvi",
				"updated": "20221112161035"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "        在 OperatorHub 中找到 “Hello World Operator”，然后按照下图的缺省配置安装。"
				}
			]
		},
