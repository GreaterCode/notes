										}
									]
								},
								{
									"Type": "NodeText",
									"Data": " （Logical datapath）：逻辑版本的OpenFlow交换机。逻辑交换机及路由器都以"
								},
								{
									"Type": "NodeCodeSpan",
									"Data": "code",
									"Children": [
										{
											"Type": "NodeCodeSpanOpenMarker"
										},
										{
											"Type": "NodeCodeSpanContent",
