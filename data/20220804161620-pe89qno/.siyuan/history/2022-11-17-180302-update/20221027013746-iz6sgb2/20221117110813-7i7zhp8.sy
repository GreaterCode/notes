			]
		},
		{
			"ID": "20221117111831-l5f246x",
			"Type": "NodeList",
			"ListData": {
				"Typ": 1
			},
			"Properties": {
				"id": "20221117111831-l5f246x",
				"updated": "20221117175536"
			},
			"Children": [
				{
					"ID": "20221117112107-94e25dm",
					"Type": "NodeListItem",
					"ListData": {
						"Typ": 1,
						"Delimiter": 46,
						"Marker": "MS4=",
						"Num": 1
					},
					"Properties": {
						"id": "20221117112107-94e25dm"
					},
					"Children": [
						{
							"ID": "20221117112107-4690ibv",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20221117112107-4690ibv",
								"updated": "20221117175252"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "MCS（MachineConfigServer）：为新加入集群的新Machine"
								},
								{
									"Type": "NodeMark",
									"Data": "mark",
									"Children": [
										{
											"Type": "NodeMark2OpenMarker"
										},
										{
											"Type": "NodeText",
											"Data": "提供Ignition配置"
										},
										{
											"Type": "NodeMark2CloseMarker"
										}
									]
								},
								{
									"Type": "NodeText",
									"Data": "。在openshift-machine-config-operator项目中它是以"
								},
								{
									"Type": "NodeMark",
									"Data": "mark",
									"Children": [
										{
											"Type": "NodeMark2OpenMarker"
										},
										{
											"Type": "NodeText",
											"Data": "DaemonSet"
										},
										{
											"Type": "NodeMark2CloseMarker"
										}
									]
								},
								{
									"Type": "NodeText",
									"Data": "的形式运行在。可以看到MCS会在每个Master节点上都运行一份，新加入节点是通过haproxy访问MCS的"
								}
							]
						}
					]
				},
				{
					"ID": "20221117175252-3qwi399",
					"Type": "NodeListItem",
					"ListData": {
						"Typ": 1,
						"Delimiter": 46,
						"Marker": "Mi4=",
						"Num": 2
					},
					"Properties": {
						"id": "20221117175252-3qwi399"
					},
					"Children": [
						{
							"ID": "20221117175252-shfysk2",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20221117175252-shfysk2",
								"updated": "20221117175309"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "MCC（MachineConfigController）：当使用MachineConfig定义了配置，MCC负责协调所有的Machines进行升级。它在openshift-machine-config-operator项目是以Deployment的方式存在的"
								}
							]
						},
						{
							"ID": "20221117175326-jnvu3um",
							"Type": "NodeList",
							"ListData": {
								"Typ": 1
							},
							"Properties": {
								"id": "20221117175326-jnvu3um"
							},
							"Children": [
								{
									"ID": "20221117175325-r22krz0",
									"Type": "NodeListItem",
									"ListData": {
										"Typ": 1,
										"Delimiter": 46,
										"Marker": "MS4=",
										"Num": 1
									},
									"Properties": {
										"id": "20221117175325-r22krz0"
									},
									"Children": [
										{
											"ID": "20221117175325-tfcbxua",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20221117175325-tfcbxua",
												"updated": "20221117175339"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "Template Controller：负责从内部模板中为machine的预定义角色（缺省是master, worker）生成MachineConfigs。"
												}
											]
										}
									]
								},
								{
									"ID": "20221117175340-y4k7nfa",
									"Type": "NodeListItem",
									"ListData": {
										"Typ": 1,
										"Delimiter": 46,
										"Marker": "Mi4=",
										"Num": 2
									},
									"Properties": {
										"id": "20221117175340-y4k7nfa"
									},
									"Children": [
										{
											"ID": "20221117175340-xp4a5px",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20221117175340-xp4a5px",
												"updated": "20221117175347"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "Render Controller：负责发现MachineConfigPoold的MachineConfigs，并生成静态MachineConfig定义文件（例如rendered-master-XXXX和rendered-worker-XXXX）。"
												}
											]
										}
									]
								},
								{
									"ID": "20221117175347-9gw4od5",
									"Type": "NodeListItem",
									"ListData": {
										"Typ": 1,
										"Delimiter": 46,
										"Marker": "My4=",
										"Num": 3
									},
									"Properties": {
										"id": "20221117175347-9gw4od5"
									},
									"Children": [
										{
											"ID": "20221117175347-w79wh29",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20221117175347-w79wh29",
												"updated": "20221117175355"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "Update Controller：负责与每台machine上运行的MCD程协调，将machine升级到MachineConfig定义的"
												}
											]
										}
									]
								},
								{
									"ID": "20221117175357-9tkit9k",
									"Type": "NodeListItem",
									"ListData": {
										"Typ": 1,
										"Delimiter": 46,
										"Marker": "NC4=",
										"Num": 4
									},
									"Properties": {
										"id": "20221117175357-9tkit9k"
									},
									"Children": [
										{
											"ID": "20221117175357-g93y81t",
											"Type": "NodeParagraph",
											"Properties": {
												"id": "20221117175357-g93y81t",
												"updated": "20221117175410"
											},
											"Children": [
												{
													"Type": "NodeText",
													"Data": "KubeletConfigController ：负责将获得的KubeletConfig CRD配置对象实施到节点的kubelet运行环境中。\n "
												}
											]
										}
									]
								}
							]
						}
					]
				},
				{
					"ID": "20221117175509-ywuemzb",
					"Type": "NodeListItem",
					"ListData": {
						"Typ": 1,
						"Delimiter": 46,
						"Marker": "My4=",
						"Num": 3
					},
					"Properties": {
						"id": "20221117175509-ywuemzb",
						"updated": "20221117175536"
					},
					"Children": [
						{
							"ID": "20221117175509-p2iirw3",
							"Type": "NodeParagraph",
							"Properties": {
								"id": "20221117175509-p2iirw3",
								"updated": "20221117175536"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "MCD（MachineConfigDaemon）：负责在升级过程中对Machine实施新的MachineConfig。它在openshift-machine-config-operator项目中MCD是以DaemonSet运行在集群中的所有节点上。另外MCD还负责通过OSTree对RHCOS进行滚动升级。\n"
								},
								{
									"Type": "NodeBr",
									"Data": "br"
								}
							]
						}
					]
				}
			]
		}
	]
}