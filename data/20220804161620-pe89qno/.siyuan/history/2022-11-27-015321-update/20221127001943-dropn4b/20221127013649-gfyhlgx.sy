										{
											"Type": "NodeCodeSpanContent",
											"Data": "/etc/cni/net.d/"
										},
										{
											"Type": "NodeCodeSpanCloseMarker"
										}
									]
								},
								{
									"Type": "NodeText",
									"Data": " 路径下无其他网络插件配置文件。如果之前安装过其他网络插件，建议删除后重启机器清理残留网络资源。"
								}
							]
						}
					]
				}
			]
		},
