					"Type": "NodeText",
					"Data": "2.3 安装脚本"
				}
			]
		},
		{
			"ID": "20221127014720-fnwrp07",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221127014720-fnwrp07",
				"updated": "20221127014826"
