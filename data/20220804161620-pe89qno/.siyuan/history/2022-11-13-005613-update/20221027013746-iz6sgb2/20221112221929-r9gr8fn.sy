					"Data": "1. 安装gitlab "
				}
			]
		},
		{
			"ID": "20221112222030-c5ma93p",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221112222030-c5ma93p",
				"updated": "20221112222115"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\t"
				},
				{
					"Type": "NodeEmphasis",
					"Data": "em",
					"Children": [
						{
							"Type": "NodeEmA6kOpenMarker",
							"Data": "*"
						},
						{
							"Type": "NodeText",
							"Data": "本文已经在OpenShift 4.10环境中验证"
						},
						{
							"Type": "NodeEmA6kCloseMarker",
							"Data": "*"
