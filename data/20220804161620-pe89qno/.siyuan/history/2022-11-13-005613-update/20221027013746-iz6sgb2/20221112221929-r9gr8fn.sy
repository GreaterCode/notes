							"Properties": {
								"id": "20221112222414-5kdheav"
							},
							"Children": [
								{
									"Type": "NodeText",
									"Data": "管理 OpenShift 容器平台中的 GitLab 实例的整个生命周期。"
								}
							]
						}
					]
				}
			]
		},
