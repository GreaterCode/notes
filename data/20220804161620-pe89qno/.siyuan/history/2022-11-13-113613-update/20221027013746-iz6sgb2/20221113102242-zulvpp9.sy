			"Children": [
				{
					"Type": "NodeCodeBlockFenceOpenMarker",
					"Data": "```"
				},
				{
					"Type": "NodeCodeBlockFenceInfoMarker",
					"CodeBlockInfo": "c2hlbGw="
				},
				{
					"Type": "NodeCodeBlockCode",
					"Data": "$ oc new-project minio-client\n$ oc apply -f - \u003c\u003c EOF\napiVersion: v1\nkind: Pod\nmetadata:\n  name: minio-client\n  namespace: minio-client\nspec:\n  containers:\n    - name: minio-client\n      image: busybox\n      command: [ \"/bin/sh\", \"-c\", \"while true ; do date; sleep 1; done;\" ]\n  restartPolicy: Never\nEOF\n\n"
				},
				{
					"Type": "NodeCodeBlockFenceCloseMarker",
					"Data": "```"
				}
			]
		},
