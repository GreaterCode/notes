			"Children": [
				{
					"Type": "NodeText",
					"Data": "1. Openshift节点运行容器过程"
				}
			]
		},
		{
			"ID": "20221115140035-ciahczw",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20221115140035-ciahczw",
				"updated": "20221115140050"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "\tOpenShift 4的集群节点使用了基于CRI-O的容器运行环境。每个节点的kubelet通过gRPC调用CRI-O，而CRI-O运行符合OCI规范的容器。"
				}
			]
		},
