																{
																	"Type": "NodeText",
																	"Data": "当CMS更新北向数据库中的配置时，作为同一事务的一部分，它将增加"
																},
																{
																	"Type": "NodeCodeSpan",
																	"Data": "code",
																	"Children": [
																		{
																			"Type": "NodeCodeSpanOpenMarker"
