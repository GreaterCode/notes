							"Children": [
								{
									"Type": "NodeText",
									"Data": "执行以下命令，然后在“ "
								},
								{
									"Type": "NodeStrong",
									"Data": "strong",
									"Children": [
										{
											"Type": "NodeStrongA6kOpenMarker",
