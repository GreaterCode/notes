							"IsFencedCodeBlock": true,
							"Properties": {
								"id": "20221117021940-4taz9p8",
								"updated": "20221117022011"
							},
							"Children": [
								{
									"Type": "NodeCodeBlockFenceOpenMarker",
									"Data": "```"
								},
								{
									"Type": "NodeCodeBlockFenceInfoMarker",
									"CodeBlockInfo": "XA=="
								},
								{
									"Type": "NodeCodeBlockCode",
									"Data": "$ openssl passwd -1 -salt yoursalt\nPassword:\n$1$yoursalt$7/tmQXmlhL0pYfN/fyBZS1\n"
								},
								{
									"Type": "NodeCodeBlockFenceCloseMarker",
									"Data": "```"
