					"Type": "NodeCodeBlockCode",
					"Data": "kind: ConfigMap\napiVersion: v1\nmetadata:\n  name: ovn-vpc-nat-gw-config\n  namespace: kube-system\ndata:\n  image: 'kubeovn/vpc-nat-gateway:v1.10.7' \n  enable-vpc-nat-gw: 'true'\n"
