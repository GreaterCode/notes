			"Children": [
				{
					"Type": "NodeText",
					"Data": "额外建立本地分支"
				}
			]
		},
		{
			"ID": "20260228023447-uclsejf",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260228023447-uclsejf",
				"updated": "20260228023447"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "命令展示："
				}
			]
		},
		{
			"ID": "20260228023447-87kjzqa",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260228023447-87kjzqa",
				"updated": "20260228023447"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "//查看当前远程的版本\ngit remote  -v\n//获取最新代码到本地临时分支(本地当前分支为[branch]，获取的远端的分支为[origin/branch])\ngit fetch origin master:master1      [示例1：在本地建立master1分支，并下载远端的origin/master分支到master1分支中]\ngit fetch origin dev:dev1     [示例2：在本地建立dev1分支，并下载远端的origin/dev分支到dev1分支中]\n//查看版本差异\ngit diff  master1    [示例1：查看本地master1分支与当前分支的版本差异]\ngit diff dev1         [示例2：查看本地dev1分支与当前分支的版本差异]\n//合并最新分支到本地分支\ngit merge master1    [示例1：合并本地分支master1到当前分支]\ngit merge dev1   [示例2：合并本地分支dev1到当前分支]\n//删除本地临时分支\ngit branch -D master1    [示例1：删除本地分支master1]\ngit branch -D dev1   [示例1：删除本地分支dev1]"
				}
			]
		},
		{
			"ID": "20260228023447-qae4f7m",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260228023447-qae4f7m",
				"updated": "20260228023553"
			},
			"Children": [
