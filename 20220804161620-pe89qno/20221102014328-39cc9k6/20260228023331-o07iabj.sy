		},
		{
			"ID": "20260228023447-alwgoqf",
			"Type": "NodeParagraph",
			"Properties": {
				"id": "20260228023447-alwgoqf",
				"updated": "20260228023447"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "//查询当前远程的版本\ngit remote -v\n//获取最新代码到本地(本地当前分支为[branch]，获取的远端的分支为[origin/branch])\ngit fetch origin master  [示例1：获取远端的origin/master分支]\ngit fetch origin dev [示例2：获取远端的origin/dev分支]\n//查看版本差异\ngit log -p master..origin/master [示例1：查看本地master与远端origin/master的版本差异]\ngit log -p dev..origin/dev   [示例2：查看本地dev与远端origin/dev的版本差异]\n//合并最新代码到本地分支\ngit merge origin/master  [示例1：合并远端分支origin/master到当前分支]\ngit merge origin/dev [示例2：合并远端分支origin/dev到当前分支]"
				}
			]
		},
		{
			"ID": "20260228023447-3jen0xw",
			"Type": "NodeParagraph",
