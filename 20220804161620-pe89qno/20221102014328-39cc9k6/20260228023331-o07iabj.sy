				"updated": "20260228023524"
			},
			"Children": [
				{
					"Type": "NodeText",
					"Data": "//查询当前远程分支\ngit remote -v\n//直接拉取并合并最新代码\ngit pull origin master    [示例1：拉取远端origin/master分支合并到本地当前分支]\ngit pull origin dev        [示例2：拉取远端origin/dev分支合并到本地当前分支]\n\n"
				}
			]
		}
	]
